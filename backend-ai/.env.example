# Backend & AI — server-side environment template.
# Copy to .env (gitignored). These are SERVER secrets — never expose to clients.
# In production, prefer Firebase Functions config / Secret Manager over .env.

# --- Email (transactional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Indigen World <no-reply@example.org>"

# --- Paystack (server-side secret key — NOT the public key) ---
PAYSTACK_SECRET_KEY=

# --- AI providers (none connected yet — placeholders for future work) ---
# AI_PROVIDER=
# AI_API_KEY=
