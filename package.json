{
  "name": "tribestudio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node node_modules/typescript/bin/tsc -b && node node_modules/vite/bin/vite.js build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "firebase:login": "npx firebase login",
    "firebase:init": "npx firebase init",
    "firebase:deploy": "npx firebase deploy",
    "firebase:deploy:hosting": "npx firebase deploy --only hosting",
    "firebase:deploy:rules": "npx firebase deploy --only firestore:rules,storage"
  },
  "dependencies": {
    "firebase": "^12.13.0",
    "framer-motion": "^12.40.0",
    "html2canvas": "^1.4.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0"
  }
