{
  "name": "indigen-world",
  "private": true,
  "version": "0.0.0",
  "description": "Indigen World monorepo — public website, TribeStudio workspace, mobile app, and shared backend/AI.",
  "workspaces": [
    "indigen-world-web",
    "tribestudio"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace indigen-world-web",
    "dev:studio": "npm run dev --workspace tribestudio",
    "build:web": "npm run build --workspace indigen-world-web",
    "build:studio": "npm run build --workspace tribestudio",
    "preview:web": "npm run preview --workspace indigen-world-web",
    "preview:studio": "npm run preview --workspace tribestudio",
    "test:web": "npm run test --workspace indigen-world-web",
    "test:studio": "npm run test --workspace tribestudio",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  }
}
