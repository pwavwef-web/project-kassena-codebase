rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && currentUserDoc().data.role == 'admin';
    }

    function isValidator() {
      return isSignedIn() && (
        currentUserDoc().data.role == 'validator' ||
        currentUserDoc().data.role == 'admin'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isOwnUserFavorite(favoriteId) {
      return isSignedIn() && favoriteId.matches('^' + request.auth.uid + '_.*');
    }

    function validDonationCreate() {
      return request.resource.data.keys().hasOnly([
        'userId',
        'name',
        'email',
        'country',
        'amount',
        'currency',
        'tier',
        'message',
        'anonymous',
        'publicDisplay',
        'reference',
        'status',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.name is string
      && request.resource.data.name.size() <= 120
      && request.resource.data.email is string
      && request.resource.data.email.size() <= 160
      && request.resource.data.email.matches('.*@.*')
      && request.resource.data.country is string
      && request.resource.data.country.size() <= 80
      && request.resource.data.amount is number
      && request.resource.data.amount >= 10
      && request.resource.data.amount <= 100000
      && request.resource.data.currency == 'GHS'
      && request.resource.data.tier in [
        'language-friend',
        'community-supporter',
        'language-champion',
        'cultural-guardian',
        'strategic-supporter',
        'data-drive',
        'custom'
      ]
      && request.resource.data.reference is string
      && request.resource.data.reference.size() >= 8
      && request.resource.data.reference.size() <= 100
      && request.resource.data.message is string
      && request.resource.data.message.size() <= 500
      && request.resource.data.status == 'pending'
      && request.resource.data.anonymous is bool
      && request.resource.data.publicDisplay is bool
      && request.resource.data.publicDisplay == !request.resource.data.anonymous
      && request.resource.data.createdAt == request.time
      && request.resource.data.updatedAt == request.time
      && (
        request.resource.data.userId == null ||
        (isSignedIn() && request.resource.data.userId == request.auth.uid)
      );
    }

    function validNewsletterCreate() {
      return request.resource.data.keys().hasOnly([
        'email',
        'source',
        'createdAt'
      ])
      && request.resource.data.email is string
      && request.resource.data.email.size() <= 160
      && request.resource.data.email.matches('.*@.*\\..*')
      && request.resource.data.source is string
      && request.resource.data.source.size() <= 80
      && request.resource.data.createdAt == request.time;
    }

    function validContactCreate() {
      return request.resource.data.keys().hasOnly([
        'name',
        'email',
        'enquiryType',
        'organization',
        'subject',
        'message',
        'status',
        'createdAt'
      ])
      && request.resource.data.name is string
      && request.resource.data.name.size() > 0
      && request.resource.data.name.size() <= 120
      && request.resource.data.email is string
      && request.resource.data.email.size() <= 160
      && request.resource.data.email.matches('.*@.*\\..*')
      && request.resource.data.enquiryType is string
      && request.resource.data.enquiryType.size() <= 60
      && request.resource.data.organization is string
      && request.resource.data.organization.size() <= 160
      && request.resource.data.subject is string
      && request.resource.data.subject.size() <= 160
      && request.resource.data.message is string
      && request.resource.data.message.size() > 0
      && request.resource.data.message.size() <= 4000
      && request.resource.data.status == 'new'
      && request.resource.data.createdAt == request.time;
    }

    function validSponsorCreate() {
      return request.resource.data.keys().hasOnly([
        'organization',
        'amount',
        'package',
        'contactName',
        'contactEmail',
        'message',
        'status',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.organization is string
      && request.resource.data.organization.size() <= 160
      && request.resource.data.contactName is string
      && request.resource.data.contactName.size() <= 120
      && request.resource.data.contactEmail is string
      && request.resource.data.contactEmail.size() <= 160
      && request.resource.data.contactEmail.matches('.*@.*')
      && request.resource.data.package is string
      && request.resource.data.package.size() <= 80
      && request.resource.data.message is string
      && request.resource.data.message.size() <= 700
      && request.resource.data.amount is number
      && request.resource.data.amount >= 1000
      && request.resource.data.status == 'new'
      && request.resource.data.createdAt == request.time
      && request.resource.data.updatedAt == request.time;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isValidator();
      allow list: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if (
        isOwner(userId) &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.status == resource.data.status
      ) || isAdmin();
      allow delete: if false;
    }

    match /dictionaryEntries/{entryId} {
      allow read: if resource.data.isPublished == true;
      allow create, update, delete: if isAdmin();
    }

    match /contributions/{contributionId} {
      allow create: if isSignedIn() && request.resource.data.contributorId == request.auth.uid;
      allow read: if isValidator() || (isSignedIn() && resource.data.contributorId == request.auth.uid);
      allow update: if isValidator() || (isSignedIn() && resource.data.contributorId == request.auth.uid);
      allow delete: if false;
    }

    match /uploads/{uploadId} {
      allow create: if isSignedIn() && request.resource.data.uploadedBy == request.auth.uid;
      allow read: if resource.data.isPublished == true || isValidator() || (isSignedIn() && resource.data.uploadedBy == request.auth.uid);
      allow update: if isValidator();
      allow delete: if false;
    }

    match /auditLogs/{auditId} {
      allow read: if isValidator();
      allow create: if isValidator();
      allow update, delete: if false;
    }

    match /publicStats/{statId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    match /campaignMetrics/{metricId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /donations/{donationId} {
      allow create: if validDonationCreate();
      allow get: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /publicSupporters/{supporterId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /sponsors/{sponsorId} {
      allow create: if validSponsorCreate();
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    match /rewardCatalog/{rewardId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /rewardAchievements/{achievementId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /rewardBounties/{bountyId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /contributorLevels/{levelId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /communityRecognitions/{recognitionId} {
      allow read: if isValidator() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    match /rewardRedemptions/{redemptionId} {
      allow read: if isValidator() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isValidator();
      allow delete: if false;
    }

    match /userFavorites/{favoriteId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isOwnUserFavorite(favoriteId) && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    match /recentlyViewed/{viewId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    match /searchHistory/{historyId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    match /announcements/{announcementId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.isPublished == true);
      allow create, update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isValidator();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // Public marketing-site lead capture: create-only for anyone, readable
    // only by admins. No public reads of submitted contact details.
    match /newsletterSubscribers/{subscriberId} {
      allow create: if validNewsletterCreate();
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    match /contactMessages/{messageId} {
      allow create: if validContactCreate();
      allow read, update: if isAdmin();
      allow delete: if false;
    }
  }
}
