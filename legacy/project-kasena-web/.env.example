# Example environment variables for local development
# Copy this file to `.env` and replace the placeholder with your real keys.

# Public Paystack key (safe to use on the client). Example starts with `pk_test_...` or `pk_live_...` for production.
VITE_PAYSTACK_PUBLIC_KEY=pk_test_YOUR_PUBLIC_KEY_HERE

# NOTE: Never put your Paystack secret key in frontend code or this file. Keep secret keys on the server/cloud functions.
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
