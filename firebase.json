{
  "hosting": [
    {
      "target": "web",
      "public": "indigen-world-web/dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [{ "source": "**", "destination": "/index.html" }]
    },
    {
      "target": "studio",
      "public": "tribestudio/dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [{ "source": "**", "destination": "/index.html" }]
    }
  ],
  "firestore": {
    "rules": "backend-ai/firebase/firestore.rules",
    "indexes": "backend-ai/firebase/firestore.indexes.json"
  },
  "storage": {
    "rules": "backend-ai/firebase/storage.rules"
  },
  "functions": [
    {
      "source": "backend-ai/firebase/functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true
    }
  ],
  "emulators": {
    "auth": { "port": 9099 },
    "functions": { "port": 5001 },
    "firestore": { "port": 8080 },
    "storage": { "port": 9199 },
    "hosting": { "port": 5000 },
    "ui": { "enabled": true },
    "singleProjectMode": true
  }
}
